  res.json({ ok: true });
});

// ─── Transfer (move items in/out of storage via GC) ───────────────────────────

// Remove item from storage unit (casket) → active inventory
app.post('/api/transfer/remove', async (req, res) => {
  const { casketId, itemId } = req.body;
  if (!casketId || !itemId) return res.status(400).json({ error: 'casketId and itemId required' });
  if (!csgo) return res.status(503).json({ error: 'GC not connected' });
  try {
    await new Promise((resolve, reject) => {
      const timeout = setTimeout(() => reject(new Error('GC timeout')), 10000);
      csgo.once('itemCustomizationNotification', (itemIds, notificationType) => {
        if (notificationType === 1014) { // CasketRemoved
          clearTimeout(timeout);
          resolve(itemIds);
        }
      });
      csgo.removeFromCasket(casketId, itemId);
    });
    log(`Transferred out: item ${itemId} from casket ${casketId}`);
    res.json({ ok: true });
  } catch(e) {
    log(`Transfer remove failed: ${e.message}`);
    res.status(500).json({ error: e.message });
  }
});

// Add item to storage unit (casket) from active inventory
app.post('/api/transfer/add', async (req, res) => {
  const { casketId, itemId } = req.body;
  if (!casketId || !itemId) return res.status(400).json({ error: 'casketId and itemId required' });
  if (!csgo) return res.status(503).json({ error: 'GC not connected' });
  try {
    await new Promise((resolve, reject) => {
      const timeout = setTimeout(() => reject(new Error('GC timeout')), 10000);
      csgo.once('itemCustomizationNotification', (itemIds, notificationType) => {
        if (notificationType === 1013) { // CasketAdded
          clearTimeout(timeout);
          resolve(itemIds);
        }
      });
      csgo.addToCasket(casketId, itemId);
    });
    log(`Transferred in: item ${itemId} to casket ${casketId}`);
    res.json({ ok: true });
  } catch(e) {
    log(`Transfer add failed: ${e.message}`);
    res.status(500).json({ error: e.message });
  }
});

// ─── Tradeup endpoints ───────────────────────────────────────────────────────

// Compute outcomes (pure math, no GC)
app.post('/api/tradeup/outcomes', (req, res) => {
  const { items } = req.body; // [{item_name, item_paint_wear}]
  if (!items || !Array.isArray(items) || items.length < 1)
    return res.status(400).json({ error: 'items array required' });
  try {
    const result = computeTradeupOutcomes(items);
    if (result.ineligible) {
      return res.status(400).json({ error: 'ineligible', ineligible: result.ineligible });
    }
    res.json({ outcomes: result.outcomes, averageFloat: result.averageFloat, fPrime: result.fPrime });
  } catch (e) {
    res.status(400).json({ error: e.message });
  }
});

// Note: /api/tradeup/execute was intentionally removed — tradeup execution is not supported.


// Manually trigger icon fetch for any items still missing icons
app.post('/api/fetch-icons', (req, res) => {
  if (!iconProgress.complete) {
    return res.json({ ok: false, message: 'Already running' });
  }
  res.json({ ok: true, message: 'Icon fetch started' });
  fetchMissingIcons().catch(e => log('Icon fetch error: ' + e.message));
});


// On-demand icon fetch for a single MHN — called by frontend when image is missing
// Rate-limited to 1 concurrent request to avoid hammering Steam
let iconFetchInFlight = false;
app.get('/api/icon/:mhn', async (req, res) => {
  const mhn = decodeURIComponent(req.params.mhn);
  if (!mhn) return res.status(400).json({ error: 'mhn required' });

  // Already cached?
  const cached = getIconUrl(mhn);
  if (cached) return res.json({ url: cached });

  // Don't pile up concurrent requests
  if (iconFetchInFlight) return res.json({ url: null });
  iconFetchInFlight = true;

  try {
    const url = 'https://steamcommunity.com/market/listings/730/' + encodeURIComponent(mhn) + '/render';
    const r = await axios.get(url, {
      timeout: 8000,
      params: { start: 0, count: 1, currency: 1 },
      headers: { 'User-Agent': 'Mozilla/5.0' },
    });
    const listingInfo = r.data?.listinginfo;
    const firstKey = listingInfo && Object.keys(listingInfo)[0];
    const icon = firstKey && r.data?.assets?.['730']?.['2']?.[
      listingInfo[firstKey]?.asset?.id
    ]?.icon_url;

    if (icon) {
      iconCache[mhn] = icon;
      saveIconCache();
      log('Icon fetched on-demand: ' + mhn);
      return res.json({ url: icon });
    }
    res.json({ url: null });
  } catch(e) {
    res.json({ url: null });
  } finally {
    iconFetchInFlight = false;
  }
});

app.get('/api/currency', (req, res) => {
  res.json({ currency: activeCurrency, symbol: CURRENCY_SYMBOLS[activeCurrency], rates: exchangeRates });
});
app.post('/api/currency', (req, res) => {
  const { currency } = req.body;
  if (!CURRENCY_CODES[currency]) return res.status(400).json({ error: 'Invalid currency. Use USD, EUR or GBP' });
  activeCurrency = currency;
  log('Currency set to ' + currency);
  res.json({ ok: true, currency, symbol: CURRENCY_SYMBOLS[currency] });
});

