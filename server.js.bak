    log('CS2 Valuation running at http://localhost:3000');
    const session = loadSession();
    if (session?.refreshToken) log('Saved session found for ' + (session.username || 'unknown') + ' — open browser to resume');
    else log('No saved session — open browser to log in');
  });
});
