});

// Resolve unknown sticker kit IDs by searching Steam market
app.get('/api/resolve-sticker/:kitId', async (req, res) => {
  const kitId = parseInt(req.params.kitId);
  if (!kitId) return res.status(400).json({ error: 'invalid kit id' });

  // Bug fix #5: prefer schema names first.
  const schemaName = schemaItemNames[kitId] || schemaStickers[kitId];
  if (schemaName) {
    const name = schemaName.startsWith('Sticker | ') ? schemaName : `Sticker | ${schemaName}`;
    schemaStickers[kitId] = name;
    return res.json({ name, iconUrl: iconCache[name] || null });
  }

  try {
    // Bug fix #5: fallback market query by text search.
    const searchRes = await axios.get('https://steamcommunity.com/market/search/render/', {
      params: {
        appid: 730,
        norender: 1,
        count: 1,
        query: `Sticker ${kitId}`,
      },
      timeout: 8000,
      headers: { 'User-Agent': 'Mozilla/5.0' },
    });

    if (searchRes.data?.results?.length) {
      const name = searchRes.data.results[0].name;
      schemaStickers[kitId] = name;
      if (searchRes.data.results[0].asset_description?.icon_url) {
        iconCache[name] = searchRes.data.results[0].asset_description.icon_url;
      }
      return res.json({ name, iconUrl: iconCache[name] || null });
    }
    res.json({ name: null });
  } catch(e) {
    res.status(500).json({ error: e.message });
  }
});

app.post('/api/logout', (req, res) => {
  resetSteam();
  clearSession();
  sseWrite('state', steamState);
  res.json({ ok: true });
});

app.post('/api/clear-cache', (req, res) => {
  priceCache = {};
  saveCache();
