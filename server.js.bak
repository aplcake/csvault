const CURRENCY_SYMBOLS = { USD: '$', EUR: '€', GBP: '£' };
const EXCHANGE_RATE_URL = 'https://api.exchangerate.host/latest?base=USD';
let exchangeRates = { USD: 1, EUR: 0.92, GBP: 0.79 };

function normalizePriceCache() {
  let changed = false;
  for (const [mhn, value] of Object.entries(priceCache)) {
    if (typeof value === 'number') {
      priceCache[mhn] = { usd: value, volume: null, ts: Date.now() };
      changed = true;
      continue;
    }
    if (!value || typeof value !== 'object') continue;
    if (value.usd != null) continue;
    if (value.lowest != null) {
      const oldRate = (value.currency && exchangeRates[value.currency]) || 1;
      priceCache[mhn] = {
        usd: value.lowest / oldRate,
        medianUsd: value.median != null ? value.median / oldRate : null,
        volume: value.volume ?? null,
        ts: value.ts || Date.now(),
        error: value.error || null,
      };
      changed = true;
    }
  }
  if (changed) saveCache();
}

function convertUsd(usd, currency) {
  if (usd == null) return null;
  return +(usd * (exchangeRates[currency] || 1)).toFixed(2);
}

function resolveCurrency(requested) {
  return ['USD', 'EUR', 'GBP'].includes(requested) ? requested : activeCurrency;
}

function toDisplayPrice(price, currency) {
  if (!price || typeof price !== 'object') {
    return { lowest: null, median: null, volume: null, cached: false, cacheAge: null, error: null };
  }
  const lowestUsd = price.usd ?? null;
  const medianUsd = price.medianUsd ?? lowestUsd;
  return {
    lowest: convertUsd(lowestUsd, currency),
    median: convertUsd(medianUsd, currency),
    volume: price.volume ?? null,
    cached: !!price.ts,
    cacheAge: price.ts ? Math.round((Date.now() - price.ts) / 86400000) : null,
    error: price.error || null,
  };
}

async function refreshExchangeRates() {
  try {
    const r = await axios.get(EXCHANGE_RATE_URL, { timeout: 10000, headers: { 'User-Agent': 'Mozilla/5.0' } });
    const rates = r.data?.rates || {};
    if (rates.USD && rates.EUR && rates.GBP) {
      exchangeRates = { USD: 1, EUR: rates.EUR, GBP: rates.GBP };
      log(`Exchange rates updated: EUR=${exchangeRates.EUR.toFixed(4)} GBP=${exchangeRates.GBP.toFixed(4)}`);
      return;
    }
    throw new Error('Missing expected rates in API response');
  } catch (e) {
    log('Exchange rate refresh failed: ' + e.message + ' (using last known rates)');
  }
}

