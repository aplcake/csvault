// ─── Tradeup data ─────────────────────────────────────────────────────────────
const rawCollections = require('./collections.json');
const collectionDirectory = {};
for (const [colName, items] of Object.entries(rawCollections)) {
  for (const itemName of Object.keys(items)) {
    collectionDirectory[itemName] = colName;
  }
}

const RARITY_LEVELS = {
  'Factory New': 0.07,
  'Minimal Wear': 0.15,
  'Field-Tested': 0.38,
  'Well-Worn': 0.45,
  'Battle-Scarred': 1,
};

const RARITY_HEX = {
  0: '00000A00', 1: '01000A00', 2: '02000A00', 3: '03000A00', 4: '04000A00',
  10: '0a000a00', 11: '0b000a00', 12: '0c000a00', 13: '0d000a00', 14: '0e000a00',
};

// Given the output skin's float range and the normalized f' (0-1),
// compute the actual output float and wear condition.
// f' = (avgInputFloat - inputMin) / (inputMax - inputMin)  -- computed in computeTradeupOutcomes
function getWearFromFPrime(outMin, outMax, fPrime) {
  const outMinF = parseFloat(outMin), outMaxF = parseFloat(outMax);
  const predictedFloat = outMinF + fPrime * (outMaxF - outMinF);
  for (const [wear, threshold] of Object.entries(RARITY_LEVELS)) {
    if (predictedFloat < threshold) return [wear, predictedFloat];
  }
  return ['Battle-Scarred', predictedFloat];
}

// Legacy alias kept for any callers — now correctly normalises avgFloat into fPrime
function getWearFromFloat(minWear, maxWear, avgFloat) {
  return getWearFromFPrime(minWear, maxWear, avgFloat);
}

function getPossibleOutcomeNames(colName, quality) {
  let i = 1;
  while (true) {
    const possible = [];
    for (const [name, data] of Object.entries(rawCollections[colName])) {
      if (parseInt(data.best_quality) === quality + i) possible.push(name);
    }
    if (possible.length > 0 || quality + i > 15) return possible;
    i++;
  }
}

function computeTradeupOutcomes(items) {
  let isStattrak = items[0].item_name.includes('StatTrak\u2122');
  const cleanItems = items.map(it => ({
    ...it,
    item_name: it.item_name.replace('StatTrak\u2122 ', ''),
  }));

  let average = 0;
  const seenSkins = [];
  const allPossible = [];

  // Pre-check: find any items not in collections data
  const ineligible = [...new Set(cleanItems.map(it => it.item_name))]
    .filter(name => !collectionDirectory[name]);
  if (ineligible.length > 0) return { ineligible };

  let inputMin = Infinity, inputMax = -Infinity;
  for (const item of cleanItems) {
    const col = collectionDirectory[item.item_name];
    const quality = parseInt(rawCollections[col][item.item_name].best_quality);
    const possible = getPossibleOutcomeNames(col, quality);
    for (const p of possible) { if (!seenSkins.includes(p)) seenSkins.push(p); }
    allPossible.push(...possible);
    average += item.item_paint_wear;
    // Track input skin float range for normalization
    const iMin = parseFloat(rawCollections[col][item.item_name]['min-wear']);
    const iMax = parseFloat(rawCollections[col][item.item_name]['max-wear']);
    if (iMin < inputMin) inputMin = iMin;
    if (iMax > inputMax) inputMax = iMax;
  }
  average = average / items.length;
  // Normalize average actual float into f' (0-1) using the input skin's float range
  const fPrime = inputMax > inputMin ? (average - inputMin) / (inputMax - inputMin) : average;

  const results = [];
  for (const skinName of seenSkins) {
    const col = collectionDirectory[skinName];
    const data = rawCollections[col][skinName];
    const [wearName, predictedFloat] = getWearFromFPrime(data['min-wear'], data['max-wear'], fPrime);
    const count = allPossible.filter(p => p === skinName).length;
    const pct = (100 / (allPossible.length / count)).toFixed(2);
    const displayName = isStattrak ? 'StatTrak\u2122 ' + skinName : skinName;
    results.push({
      item_name: displayName,
      item_wear_name: wearName,
      percentage: parseFloat(pct),
      float_chance: predictedFloat,
      image: data.imageURL || data.image || '',
      collection: col,
    });
  }
  results.sort((a, b) => b.percentage - a.percentage);
  return { outcomes: results, averageFloat: average, fPrime };
}

const app = express();
const server = http.createServer(app);

