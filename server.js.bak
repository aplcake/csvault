  for (const items of Object.values(cols)) {
    for (const [name, data] of Object.entries(items)) {
      const url = data.imageURL || data.image || '';
      if (url && url.startsWith('http') && !iconCache[name]) {
        iconCache[name] = url;
        seeded++;
